<Window x:Class="CurrencyExchangeWpfClient.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login — Currency Exchange Office"
        Height="320" Width="380"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title       -->
            <RowDefinition Height="Auto"/>
            <!-- Username    -->
            <RowDefinition Height="Auto"/>
            <!-- Username box-->
            <RowDefinition Height="Auto"/>
            <!-- Password    -->
            <RowDefinition Height="Auto"/>
            <!-- Password box-->
            <RowDefinition Height="Auto"/>
            <!-- Buttons     -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Currency Exchange Office"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Username:" Margin="0,5,0,2"/>
        <TextBox   Grid.Row="2" Name="UsernameTextBox" Height="25"/>

        <TextBlock Grid.Row="3" Text="Password:" Margin="0,15,0,2"/>
        <!-- PasswordBox hides the typed text with dots. -->
        <PasswordBox Grid.Row="4" Name="PasswordBox" Height="25"/>

        <!-- Two buttons side by side in the last row. -->
        <Grid Grid.Row="5" Margin="0,25,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Login"
                    Height="35"
                    Click="LoginButton_Click"/>

            <Button Grid.Column="2"
                    Content="Register"
                    Height="35"
                    Click="RegisterButton_Click"/>
        </Grid>
    </Grid>
</Window>