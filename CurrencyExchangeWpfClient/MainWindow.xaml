<Window x:Class="CurrencyExchangeWpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office"
        Height="600" Width="450"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
           Text="Esenov Kantor"
           FontSize="20" FontWeight="Bold"
           HorizontalAlignment="Center"
           Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1"
                   Text="Currency Exchange Office"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <TextBlock Grid.Row="2"
                   Name="UserInfoTextBlock"
                   Text=""
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Name="BalanceTextBlock"
                       Text="Balance: 0 PLN"
                       VerticalAlignment="Center"
                       FontWeight="Bold"/>

            <TextBox Grid.Column="1"
                     Name="TopUpAmountTextBox"
                     Width="80" Height="25"
                     Margin="10,0,5,0"/>

            <Button Grid.Column="2"
                    Content="Top up"
                    Height="25"
                    Padding="10,0"
                    Click="TopUpButton_Click"/>
        </Grid>

        <TextBlock Grid.Row="4" Text="Amount:" Margin="0,5,0,2"/>
        <TextBox   Grid.Row="5" Name="AmountTextBox" Height="25"/>

        <TextBlock Grid.Row="6" Text="From:" Margin="0,15,0,2"/>
        <ComboBox  Grid.Row="7" Name="FromComboBox" Height="25"/>

        <TextBlock Grid.Row="8" Text="To:" Margin="0,15,0,2"/>
        <ComboBox  Grid.Row="9" Name="ToComboBox" Height="25"/>

        <Button Grid.Row="10"
                Name="ExchangeButton"
                Content="Exchange"
                Height="35"
                Margin="0,20,0,0"
                Click="ExchangeButton_Click"/>

        <TextBlock Grid.Row="11"
                   Name="ResultTextBlock"
                   Text=""
                   FontSize="14"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,15,0,0"/>
    </Grid>
</Window>