<Window x:Class="CurrencyExchangeWpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office"
        Height="500" Width="450"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
           Text="Esenov kantor"
           FontSize="20" FontWeight="Bold"
           HorizontalAlignment="Center"
           Margin="0,0,0,0"/>

        <TextBlock Grid.Row="1"
                   Text="Currency Exchange Office"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="2" Text="Amount:" Margin="0,5,0,2"/>
        <TextBox   Grid.Row="3" Name="AmountTextBox" Height="25"/>

        <TextBlock Grid.Row="4" Text="From:" Margin="0,15,0,2"/>
        <ComboBox  Grid.Row="5" Name="FromComboBox" Height="25"/>

        <TextBlock Grid.Row="6" Text="To:" Margin="0,15,0,2"/>
        <ComboBox  Grid.Row="7" Name="ToComboBox" Height="25"/>

        <Button Grid.Row="8"
                Name="ExchangeButton"
                Content="Exchange"
                Height="35"
                Margin="0,25,0,0"
                Click="ExchangeButton_Click"/>

        <TextBlock Grid.Row="9"
                   Name="ResultTextBlock"
                   Text=""
                   FontSize="14"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"/>
    </Grid>
</Window>