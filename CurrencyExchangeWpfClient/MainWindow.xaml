<Window x:Class="CurrencyExchangeWpfClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office"
        Height="750" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
           Text="Esenov Kantor"
           FontSize="20" FontWeight="Bold"
           HorizontalAlignment="Center"
           Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1"
                   Text="Currency Exchange Office"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2"
                   Name="UserInfoTextBlock"
                   Text=""
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Top up PLN:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <TextBox Grid.Column="1"
                     Name="TopUpAmountTextBox"
                     Height="25"/>

            <Button Grid.Column="2"
                    Content="Top up"
                    Height="25"
                    Padding="15,0"
                    Margin="5,0,0,0"
                    Click="TopUpButton_Click"/>
        </Grid>

        <TextBlock Grid.Row="4"
                   Text="Your balances:"
                   FontWeight="Bold"
                   Margin="0,5,0,5"/>

        <ListBox Grid.Row="5"
                 Name="BalancesListBox"
                 Height="120"
                 Margin="0,0,0,15"/>

        <TextBlock Grid.Row="6"
                   Text="Buy currency:"
                   FontWeight="Bold"
                   Margin="0,5,0,5"/>

        <TextBlock Grid.Row="7" Text="Amount to spend:" Margin="0,5,0,2"/>
        <TextBox   Grid.Row="8" Name="AmountTextBox" Height="25"/>

        <TextBlock Grid.Row="9" Text="Spend from:" Margin="0,10,0,2"/>
        <ComboBox  Grid.Row="10" Name="FromComboBox" Height="25"/>

        <TextBlock Grid.Row="11" Text="Receive in:" Margin="0,10,0,2"/>
        <ComboBox  Grid.Row="12" Name="ToComboBox" Height="25"/>

        <Button Grid.Row="13"
                Content="Buy"
                Height="35"
                Margin="0,15,0,0"
                Click="BuyButton_Click"/>

        <TextBlock Grid.Row="14"
                   Name="StatusTextBlock"
                   Text=""
                   FontSize="13"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>